# ============================================
# FF2 Environment Configuration
# ============================================
# Copy this file to .env and fill in the values

# Database (Vercel / production: ใช้ Postgres เช่น Neon, Supabase, Vercel Postgres — ห้ามใช้ SQLite บน Vercel)
# ตัวอย่าง Neon: postgresql://USER:PASSWORD@HOST/db?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ff2?schema=public"

# Application URL
NEXTAUTH_URL="http://localhost:3000"

# ⚠️ SECURITY: Generate a new secret for production!
# Run: openssl rand -base64 32
NEXTAUTH_SECRET="your-secure-secret-at-least-32-characters"

# Session encryption key
# Run: openssl rand -base64 32
SESSION_SECRET="another-secure-secret-at-least-32-characters"

# Environment (development or production)
NODE_ENV="development"
