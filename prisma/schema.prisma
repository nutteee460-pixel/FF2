generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  lineId    String   @default("")
  phone     String?
  province  String?
  district  String?
  role      String   @default("USER") // USER, ADMIN
  accountType String @default("POSTER") // POSTER = ลงขาย/โพสต์งาน, BUYER = ผู้ใช้งานทั่วไป (ผู้สมัครใหม่เลือกเอง)
  isBanned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  profiles      Profile[]
  creditHistory CreditHistory[]
}

model Profile {
  id          String   @id @default(cuid())
  userId      String
  name        String
  age         Int
  province     String
  district    String?
  description String?
  images      String   // JSON array of image URLs
  tier        String   @default("FREE") // SUPER, MODEL, FREE
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  // หมวดหมู่ใหม่
  serviceTypes String   @default("[]") // JSON array: เช่น ["ถ่ายรูป", "พรีเซนเตอร์", "งาน Event", "เดท"]
  appearance   String   @default("[]") // JSON array: เช่น ["สูง", "ผอม", "อวบ", "ผิวขาว", "ผิวเข้ม"]
  ageRange     String   @default("[]") // JSON array: เช่น ["18-22", "23-30", "30-40"]
  region       String   @default("")  // ภาค: "central", "north", "south", "northeast", "east", "west"
  
  // Expiry dates
  superExpiry DateTime?
  modelExpiry DateTime?
  freeExpiry  DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts          Post[]
  creditHistory  CreditHistory[]
  transferLogsFrom TransferLog[] @relation("FromProfile")
  transferLogsTo   TransferLog[] @relation("ToProfile")
}

model Post {
  id          String   @id @default(cuid())
  profileId   String
  title       String
  description String?
  images      String   // JSON array of image URLs
  lineId      String   @default("") // ช่องทางติดต่อ LINE (กรอกตอนสร้างโพสต์)
  contactName String?  // ชื่อที่แสดง (ไม่บังคับ)
  age         Int?     // อายุที่แสดงในโพสต์ (กรอกตอนสร้างโพสต์, ต้องไม่ต่ำกว่า 20)
  province    String?
  district    String?
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  adminNotes  String?
  
  // หมวดหมู่
  serviceTypes String   @default("[]")
  appearance   String   @default("[]")
  ageRange     String   @default("[]")
  region       String   @default("")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model CreditHistory {
  id        String   @id @default(cuid())
  userId    String
  profileId String?  // โปรไฟล์ที่ซื้อวันให้ (nullable สำหรับรายการเก่า)
  amount    Int      // Days added
  type      String   // TOPUP, PURCHASE_SUPER, PURCHASE_MODEL
  proof     String?  // Payment slip image URL
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  adminNotes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
}

model TransferLog {
  id            String   @id @default(cuid())
  fromProfileId String
  toProfileId   String
  days         Int
  createdAt    DateTime @default(now())
  
  fromProfile Profile @relation("FromProfile", fields: [fromProfileId], references: [id], onDelete: Cascade)
  toProfile   Profile @relation("ToProfile", fields: [toProfileId], references: [id], onDelete: Cascade)
}

model Settings {
  id            String  @id @default("default")
  bankName      String?
  bankAccount   String?
  bankNumber    String?
  telegramChannel String?
  updatedAt     DateTime @updatedAt
}

model Package {
  id          String   @id @default(cuid())
  name        String   // SUPER, MODEL
  price7Days  Int      @default(5)   // ราคา 7 วัน (บาท)
  price14Days Int      @default(5)   // ราคา 14 วัน (บาท)
  description String?              // คำอธิบายแพ็คเกจ
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
